# ---------- 模型提供方（anthropic | qwen）----------
# 默认 anthropic（Claude）。qwen / dashscope 均走阿里云 DashScope 通义千问兼容接口。
AI_PROVIDER=anthropic

# ---------- Anthropic（AI_PROVIDER=anthropic 或未设置时）----------
ANTHROPIC_API_KEY=
# 可选，默认 claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------- 通义千问（AI_PROVIDER=qwen）----------
# 在阿里云百炼 / DashScope 控制台创建 API-KEY
DASHSCOPE_API_KEY=
# 可选，默认 qwen-plus
# QWEN_MODEL=qwen-plus
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_STREAM_USAGE=true

# 本地 dev API 端口（与 Vite 代理一致）
PORT_API=8787

# ---------- 阅文开放平台（起点系）元数据检索增强（可选）----------
# 未申请/未配置则会自动降级为纯大模型推荐
YUEWEN_ENABLE=false
# 申请阅文开放平台后获取
YUEWEN_APP_KEY=
# 如不填，代码将尝试按文档规则由 appKey 计算（基于 MD5）
# YUEWEN_APP_TOKEN=

# 取候选集时的分页/数量（影响“全面性”和延迟）
YUEWEN_PAGE_SIZE=20
YUEWEN_PAGES_PER_QUERY=3
YUEWEN_BOOKINFO_LIMIT=20
YUEWEN_BOOKS_FOR_PROMPT=8
YUEWEN_MAX_PARALLEL=5
YUEWEN_TIMEOUT_MS=8000
